@inherits PanelComponent

<root style="width: 100%; height: 100%;">
	<div style="width: 100%; height: 100%; background-color: rgba(40,40,40,0.85); border-radius: 4px; position: relative; overflow: hidden;">
		<div style="width: @(FillPercent)%; height: 100%; background-color: rgba(200,20,20,0.9); position: absolute; left: 0; top: 0;"></div>
		<label style="position: absolute; width: 100%; height: 100%; text-align: center; color: white; font-size: 28px; font-weight: bold; display: flex; align-items: center; justify-content: center;">@HP / 100</label>
	</div>
</root>

@code
{
	Health Health => GameObject?.Parent?.Components.Get<Health>();

	float FillPercent => Health is not null ? (Health.Current / Health.MaxHealth * 100f) : 100f;
	int HP => Health is not null ? (int)Health.Current : 100;

	protected override void OnUpdate()
	{
		StateHasChanged();
	}
}
